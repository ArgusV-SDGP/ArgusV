# =============================================================================
#  ArgusV — .gitignore
#  Covers: Python/uv, FastAPI, Docker, Alembic, YOLO/ML, HLS/Video,
#          Recordings, Logs, Secrets, IDE tooling, OS artefacts
# =============================================================================

__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd


# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py.cover
.hypothesis/
.pytest_cache/
cover/

# Type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/

# Jupyter / IPython
.ipynb_checkpoints
profile_default/
ipython_config.py

# Celery
celerybeat-schedule
celerybeat.pid

# Cython debug symbols
cython_debug/

# Translations
*.mo
*.pot

# SageMath
*.sage.py


# -----------------------------------------------------------------------------
# 📦  Package managers (uv, pip, pipenv, poetry, pdm, pixi)
# -----------------------------------------------------------------------------

# uv — keep uv.lock committed for reproducibility; ignore the venv
.venv/
.venv*/

# pipenv / poetry / pdm / pixi virtual-env artefacts
__pypackages__/
.pdm-python
.pdm-build/
.pixi/
.pixi*/

# pip
pip-log.txt
pip-delete-this-directory.txt

# PyPI
.pypirc


# -----------------------------------------------------------------------------
# 🔐  Secrets & environment
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example          # keep the example template in source control
.envrc
secrets.json
secrets.yaml
secrets.yml
*_credentials.*
service_account*.json


# -----------------------------------------------------------------------------
# 🐳  Docker
# -----------------------------------------------------------------------------
# Don't ignore docker-compose files — they're infrastructure definitions.
# But do ignore any local override files.
docker-compose.override.yml
docker-compose.local.yml


# -----------------------------------------------------------------------------
# 🗄️  Database / Alembic
# -----------------------------------------------------------------------------
# Keep alembic/versions/ committed (migration scripts), but ignore local DBs.
*.db
*.sqlite
*.sqlite3
*.sqlite3-journal

# PostgreSQL dump files
*.dump
*.pgdump
*.sql.gz


# -----------------------------------------------------------------------------
# 🎥  Video, HLS & recording pipeline artefacts
# -----------------------------------------------------------------------------

# HLS live stream segments & playlists (generated at runtime)
*.m3u8
*.ts
*.m4s
*.fmp4

# FFmpeg / MediaMTX intermediates
*.h264
*.h265
*.avc

# Recordings directory — contains large binary files generated at runtime.
# Keep the folder structure via .gitkeep files instead.
argusv/recordings/*/
!argusv/recordings/**/.gitkeep

# Clips and snapshots (runtime output)
argusv/assets/clips/
argusv/assets/snapshots/
argusv/tmp/

# Generic temp / HLS output dirs used across services
tmp/
hls_output/
stream_output/
output/


# -----------------------------------------------------------------------------
# 🤖  AI / ML model weights
# -----------------------------------------------------------------------------
# Large binary model files — store in a model registry, not Git.
*.pt
*.pth
*.onnx
*.tflite
*.pb
*.h5
*.pkl
*.pickle
*.joblib
*.safetensors
*.bin

# YOLO-specific
runs/
weights/


# -----------------------------------------------------------------------------
# 📋  Logs & debug artefacts
# -----------------------------------------------------------------------------
*.log
*.log.*
logs/
recorder.log
debug_out.txt

# Python debug scripts that are clearly throwaway
debug_paths.py


# -----------------------------------------------------------------------------
# 🗂️  OS artefacts
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~


# -----------------------------------------------------------------------------
# 🛠️  IDE & editor settings
# -----------------------------------------------------------------------------

# JetBrains (PyCharm, IntelliJ, etc.)
.idea/

# Visual Studio Code
.vscode/

# Cursor
.cursorignore
.cursorindexingignore

# Spyder
.spyderproject
.spyproject

# Rope
.ropeproject

# Abstra
.abstra/

# Ruff
.ruff_cache/

# Marimo
marimo/_static/
marimo/_lsp/
__marimo__/


# -----------------------------------------------------------------------------
# 📄  Documentation build output
# -----------------------------------------------------------------------------
docs/_build/
/site


# -----------------------------------------------------------------------------
# 🔑  Postman / HTTP client exports (may contain tokens)
# -----------------------------------------------------------------------------
*.postman_environment.json
*.postman_globals.json
ARGUSV_PRD.json        # large Postman collection — usually tracked separately
