# ArgusV development secrets
# Copy to .env and fill in your values
# NEVER commit .env to git

# ── VLM / GenAI ───────────────────────
OPENAI_API_KEY=sk-...
GENAI_PROVIDER=openai          # openai | gemini | ollama | disabled
VLM_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small
USE_TIERED_VLM=true
VLM_MAX_WORKERS=2

# ── Notifications ─────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=#argus-alerts
RATE_LIMIT_TTL_SEC=300         # seconds before same alert can fire again

# ── Camera ───────────────────────────
# RTSP_HOST: "localhost" for local dev, "mediamtx" inside Docker
RTSP_HOST=localhost
# Override with full JSON for custom cameras:
# CAMERAS=[{"id":"cam-01","name":"Front Door","rtsp_url":"rtsp://192.168.1.50:554/stream"}]

# ── Detection ─────────────────────────
YOLO_MODEL=yolo11m.pt          # yolo11n/s/m/l/x  or  yolov8n/s/m/l/x
DETECT_FPS=5
CONF_THRESHOLD=0.45
USE_MOTION_GATE=true
LOITER_THRESHOLD_SEC=30

# Object class filter (global default for all cameras).
# Pattern A — explicit COCO ID:label pairs:
#   DETECT_CLASSES=0:person,2:car,7:truck,5:bus,3:motorcycle
# Pattern B — label names (resolved from COCO-80):
#   DETECT_CLASS_NAMES=person,car,truck
# Default when neither is set: person, car, truck
DETECT_CLASS_NAMES=person,car,truck

# Per-camera overrides set via PATCH /api/cameras/{id} detect_config field.
# Per-zone class filters set via PATCH /api/zones/{id} allowed_classes field.

# ── Recording ─────────────────────────
RECORDINGS_ENABLED=false
SEGMENT_DURATION_SEC=10
RECORDINGS_RETAIN_DAYS=7
LOCAL_RECORDINGS_DIR=./recordings

# ── DB / Redis ────────────────────────
# Local dev (connecting from host to docker-compose.dev.yml): port 5434
# Local dev (connecting from host to docker-compose.yml):    port 5433
# Inside Docker (container-to-container):                    port 5432
POSTGRES_URL=postgresql://argus:password@localhost:5434/argus_db
REDIS_URL=redis://localhost:6380/0

# ── API Server ────────────────────────
LOG_LEVEL=INFO
MEDIAMTX_HLS_BASE=http://localhost:8888
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Auth / Security ─────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_MINUTES=1440
# Format: {"username":{"password":"...","role":"ADMIN|OPERATOR|VIEWER"}}
# Password can be plain text (dev) or pbkdf2_sha256$... hash.
AUTH_USERS_JSON={"admin":{"password":"admin123","role":"ADMIN"},"operator":{"password":"operator123","role":"OPERATOR"}}
# Format: {"api-key-string":{"subject":"service-client","role":"SERVICE"}}
API_KEYS_JSON={"local-dev-api-key":{"subject":"service-client","role":"SERVICE"}}

# ── Dev only — set true to bypass all auth (NEVER in prod) ──
DEV_AUTH_BYPASS=false
