# ArgusV Development environment
# Infrastructure services run in Docker, app runs locally with uvicorn --reload
# Infrastructure (localhost = Docker ports exposed to host)

POSTGRES_URL=postgresql://argus:password@localhost:5434/argus_db
REDIS_URL=redis://localhost:6380/0

RECORDINGS_ENABLED=true
# Camera ─────────────────────────────────────────────────────────
# RTSP_HOST controls where cameras connect. "localhost" for local dev,
# "mediamtx" inside Docker. Individual cameras auto-use this host.
RTSP_HOST=localhost
# Override individual cameras via CAMERAS JSON (optional).
# If not set, defaults to cam-01 + cam-02 using RTSP_HOST.
# Example for custom cameras:
# CAMERAS=[{"id":"cam-01","name":"Front Door","rtsp_url":"rtsp://localhost:8554/cam-01"},{"id":"cam-02","name":"Parking Lot","rtsp_url":"rtsp://localhost:8554/cam-02"}]

REDIS_URL=redis://localhost:6380/0


DEV_AUTH_BYPASS=true


# Detection ──────────────────────────────────────────────────────
YOLO_MODEL=yolo11m.pt          # yolo11n/s/m/l/x  or  yolov8n/s/m/l/x
DETECT_FPS=5
CONF_THRESHOLD=0.45
YOLO_MODEL=yolov8n.pt
USE_MOTION_GATE=true
MOTION_THRESHOLD=0.003
USE_TRACKER=true
LOITER_THRESHOLD_SEC=30

# Object class filter (global default for all cameras).
# Pattern A — explicit COCO ID:label pairs:
#   DETECT_CLASSES=0:person,2:car,7:truck,5:bus,3:motorcycle
# Pattern B — label names (resolved from COCO-80):
#   DETECT_CLASS_NAMES=person,car,truck
# Default when neither is set: person, car, truck
DETECT_CLASS_NAMES=person,car,truck

# Per-camera overrides set via PATCH /api/cameras/{id} detect_config field.
# Per-zone class filters set via PATCH /api/zones/{id} allowed_classes field.
RATE_LIMIT_TTL_SEC=30

# Recording (disabled for dev) ───────────────────────────────────
RECORDINGS_ENABLED=true

# VLM ─────────────────────────────────────────────────────────────
USE_TIERED_VLM=true
VLM_MAX_WORKERS=2
GENAI_PROVIDER=openai

# Notifications (optional) ───────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=#argus-alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Logging ────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG

# Authorization Bypass ───────────────────────────────────────────
# Treat every request from dev as an ADMIN request without auth
DEV_AUTH_BYPASS=true

# MediaMTX ───────────────────────────────────────────────────────
# HLS base URL served by MediaMTX — used by the dashboard frontend
# Change this in production to point to your public MediaMTX host
MEDIAMTX_HLS_BASE=http://localhost:8888



OPENAI_API_KEY=

EMBED_FRAME=true